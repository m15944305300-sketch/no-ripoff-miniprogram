page {
  background-color: #f5f5f5;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Roboto', 'Oxygen', 'Ubuntu', 'Cantarell', 'Fira Sans', 'Droid Sans', 'Helvetica Neue', sans-serif;
}

.container {
  padding: 20rpx;
}

.card {
  background: white;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.price-tag {
  color: #ff6b6b;
  font-weight: bold;
  font-size: 36rpx;
}

.grade-tag {
  display: inline-block;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
  margin-left: 12rpx;
}

.grade-A {
  background-color: #ffebee;
  color: #c62828;
}

.grade-B {
  background-color: #fff3e0;
  color: #e65100;
}

.grade-C {
  background-color: #e0e0e0;
  color: #424242;
}

.btn-primary {
  background: linear-gradient(135deg, #ff6b6b 0%, #ee5a5a 100%);
  color: white;
  border: none;
  border-radius: 12rpx;
  padding: 20rpx 40rpx;
  font-size: 28rpx;
  font-weight: 500;
}

.btn-secondary {
  background: #f5f5f5;
  color: #666;
  border: 2rpx solid #ddd;
  border-radius: 12rpx;
  padding: 20rpx 40rpx;
  font-size: 28rpx;
}