<wxs src="../../utils/helper.wxs" module="helper" />
<view class="container">
  <!-- 定位栏 -->
  <view class="location-bar">
    <text class="location-icon">📍</text>
    <text class="location-text">{{location}}</text>
  </view>

  <view class="search-bar">
    <input class="search-input" placeholder="搜索水果名称" value="{{keyword}}" bindinput="onInput" bindconfirm="search"/>
    <button class="search-btn" bindtap="search">搜索</button>
  </view>

  <view wx:if="{{searchResults.length > 0}}" class="card">
    <view class="card-header">
      <text class="card-title">搜索结果</text>
    </view>
    <view class="result-list">
      <view class="result-item" wx:for="{{searchResults}}" wx:key="id" bindtap="goToCompare" data-id="{{item.id}}" data-name="{{item.name}}">
        <view class="result-icon">{{helper.getEmoji(item.name)}}</view>
        <view class="result-info">
          <text class="result-name">{{item.name}}</text>
          <text class="result-category">{{item.category}}</text>
        </view>
        <text class="result-arrow">›</text>
      </view>
    </view>
  </view>

  <view wx:if="{{keyword && searchResults.length === 0}}" class="card">
    <text class="empty-text">未找到 "{{keyword}}"，试试其他水果</text>
  </view>

  <view wx:if="{{!keyword}}" class="card">
    <view class="card-header">
      <text class="card-title">热门搜索</text>
    </view>
    <view class="hot-tags">
      <text class="hot-tag" wx:for="{{hotFruits}}" wx:key="*this" bindtap="searchTag" data-text="{{item}}">{{item}}</text>
    </view>
  </view>

  <view wx:if="{{showPrices && currentPrices.length > 0}}" class="card">
    <view class="card-header">
      <text class="card-title">{{selectedFruit}} - 价格对比</text>
    </view>
    <!-- 等级说明 -->
    <view class="grade-legend">
      <view class="legend-item">
        <text class="grade-tag grade-A">A级</text>
        <text class="legend-desc">优质品，果形端正、色泽好</text>
      </view>
      <view class="legend-item">
        <text class="grade-tag grade-B">B级</text>
        <text class="legend-desc">合格品，略有瑕疵但品质正常</text>
      </view>
      <view class="legend-item">
        <text class="grade-tag grade-C">C级</text>
        <text class="legend-desc">普通品，外观一般或临期处理</text>
      </view>
    </view>
    <view class="price-list">
      <view class="price-item" wx:for="{{currentPrices}}" wx:key="store_id">
        <view class="price-rank">{{index + 1}}</view>
        <view class="price-info">
          <view class="store-name-row">
            <text class="store-name">{{item.store_name}}</text>
            <text wx:if="{{helper.isExternal(item.region)}}" class="region-tag">{{item.region}}</text>
          </view>
          <text class="store-type">{{item.store_type}} · {{item.source_type}}</text>
        </view>
        <view class="price-detail">
          <text class="price-value">¥{{item.price}}/{{item.unit}}</text>
          <text class="grade-tag grade-{{helper.gradeShort(item.grade)}}">{{item.grade}}</text>
        </view>
      </view>
    </view>
    <view class="best-price">
      <text class="best-label">最低价：</text>
      <text class="best-value">¥{{currentPrices[0].price}}/{{currentPrices[0].unit}} ({{currentPrices[0].store_name}})</text>
    </view>
  </view>

  <view wx:if="{{showPrices && currentPrices.length === 0}}" class="card">
    <view class="card-header">
      <text class="card-title">{{selectedFruit}} - 价格对比</text>
    </view>
    <text class="empty-text">{{selectedFruit}}今日暂无价格数据</text>
  </view>
</view>
