.fruit-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.fruit-option {
  width: calc(33.33% - 12rpx);
  background: #f8f9fa;
  border-radius: 16rpx;
  padding: 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  position: relative;
  border: 2rpx solid transparent;
}

.fruit-option.selected {
  background: #ffebee;
  border-color: #ff6b6b;
}

.fruit-icon {
  font-size: 48rpx;
  margin-bottom: 8rpx;
}

.fruit-name {
  font-size: 24rpx;
  color: #333;
}

.checkbox {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  width: 36rpx;
  height: 36rpx;
  background: #ff6b6b;
  color: white;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
}

.compare-btn {
  width: 100%;
  background: linear-gradient(135deg, #ff6b6b 0%, #ee5a5a 100%);
  color: white;
  border-radius: 12rpx;
  padding: 24rpx;
  font-size: 30rpx;
  font-weight: bold;
  margin-top: 20rpx;
  border: none;
}

.tip-text {
  text-align: center;
  color: #999;
  padding: 40rpx;
  font-size: 26rpx;
}

.clear-btn {
  font-size: 24rpx;
  color: #999;
  background: transparent;
  border: none;
}

.compare-table {
  margin-top: 10rpx;
}

.table-header {
  display: flex;
  padding: 20rpx;
  background: #f8f9fa;
  border-radius: 12rpx 12rpx 0 0;
}

.th-fruit, .th-store, .th-price, .th-grade {
  font-size: 24rpx;
  color: #666;
  font-weight: bold;
}

.th-fruit { width: 30%; }
.th-store { width: 30%; }
.th-price { width: 25%; text-align: right; }
.th-grade { width: 15%; text-align: center; }

.table-row {
  display: flex;
  padding: 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
  align-items: center;
}

.table-row:last-child {
  border-bottom: none;
}

.td-fruit {
  width: 30%;
  font-size: 26rpx;
  color: #333;
}

.td-store {
  width: 30%;
  font-size: 26rpx;
  color: #666;
}

.td-price {
  width: 25%;
  font-size: 28rpx;
  font-weight: bold;
  color: #ff6b6b;
  text-align: right;
}

.td-grade {
  width: 15%;
  text-align: center;
}

.total-info {
  background: #e3f2fd;
  padding: 20rpx;
  border-radius: 12rpx;
  margin-top: 20rpx;
  display: flex;
  align-items: center;
}

.total-label {
  font-size: 26rpx;
  color: #1976d2;
}

.total-value {
  font-size: 28rpx;
  color: #1976d2;
  font-weight: bold;
  margin-left: 8rpx;
}