.container { padding: 0 10rpx; }

.header {
  text-align: center;
  padding: 10rpx 0 12rpx 0;
  background: linear-gradient(135deg, #ff6b6b 0%, #ee5a5a 100%);
  border-radius: 0 0 16rpx 16rpx;
  margin: 0 -10rpx 8rpx -10rpx;
}
.header-top { display: flex; align-items: center; justify-content: center; margin-bottom: 4rpx; }
.location-icon { font-size: 20rpx; margin-right: 4rpx; }
.location-text { font-size: 20rpx; color: rgba(255,255,255,0.85); }
.title { font-size: 30rpx; font-weight: bold; color: white; display: block; }
.subtitle { font-size: 18rpx; color: rgba(255,255,255,0.7); display: block; }

.card { background: white; border-radius: 10rpx; padding: 10rpx 12rpx; margin-bottom: 6rpx; box-shadow: 0 1rpx 6rpx rgba(0,0,0,0.04); }
.card-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 6rpx; }
.card-title { font-size: 24rpx; font-weight: bold; color: #333; }
.fruit-count { font-size: 18rpx; color: #ff6b6b; }

/* 水果网格 - 6列 */
.fruit-grid { display: flex; flex-wrap: wrap; gap: 6rpx; }
.fruit-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 6rpx 2rpx;
  background: #f8f9fa;
  border-radius: 8rpx;
  width: calc((100% - 30rpx) / 6);
  box-sizing: border-box;
  min-height: 64rpx;
}
.fruit-hover { background: #ffe0e0; }
.fruit-selected { background: #ffebee; border: 2rpx solid #ff6b6b; }
.fruit-emoji { font-size: 26rpx; line-height: 1.1; }
.fruit-name { font-size: 16rpx; color: #333; line-height: 1.1; margin-top: 1rpx; }

/* 走势摘要 */
.trend-summary { padding: 8rpx 0; margin-bottom: 4rpx; border-bottom: 1rpx dashed #eee; }
.summary-text { font-size: 20rpx; color: #666; }

/* 走势列表 */
.trend-list { }
.trend-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}
.trend-item:last-child { border-bottom: none; }

.trend-left { flex: 1; min-width: 0; }
.store-name-row { display: flex; align-items: center; }
.store-name { font-size: 22rpx; color: #333; display: block; }
.store-type { font-size: 16rpx; color: #999; margin-top: 2rpx; display: block; }

.region-tag {
  display: inline-block;
  padding: 1rpx 6rpx;
  background: #e3f2fd;
  color: #1976d2;
  font-size: 14rpx;
  border-radius: 4rpx;
  margin-left: 4rpx;
}

.trend-right { display: flex; flex-direction: column; align-items: flex-end; flex-shrink: 0; }
.trend-price { display: flex; flex-direction: column; align-items: flex-end; }
.price-today { font-size: 28rpx; font-weight: bold; color: #ff6b6b; }
.price-yesterday { font-size: 18rpx; color: #bbb; margin-top: 2rpx; }

/* 涨跌 */
.trend-change { display: flex; align-items: center; margin-top: 4rpx; }
.trend-change.down { color: #4caf50; }
.trend-change.up { color: #ff6b6b; }
.trend-change.flat { color: #999; }
.change-arrow { font-size: 18rpx; margin-right: 2rpx; }
.change-text { font-size: 22rpx; font-weight: bold; }
.change-pct { font-size: 16rpx; margin-left: 2rpx; }
.trend-no-data { font-size: 18rpx; color: #ccc; margin-top: 4rpx; }

.empty-text { text-align: center; color: #999; padding: 12rpx; font-size: 20rpx; }
.retry-btn {
  display: inline-block;
  margin-top: 8rpx;
  padding: 8rpx 30rpx;
  background: linear-gradient(135deg, #ff6b6b 0%, #ee5a5a 100%);
  color: white;
  border-radius: 20rpx;
  font-size: 20rpx;
}

.guide-row { display: flex; justify-content: space-around; padding: 12rpx 0; }
.guide-item { display: flex; align-items: center; padding: 6rpx 12rpx; border-radius: 6rpx; }
.guide-hover { background: #f0f0f0; }
.guide-icon { font-size: 24rpx; margin-right: 4rpx; }
.guide-text { font-size: 18rpx; color: #666; }