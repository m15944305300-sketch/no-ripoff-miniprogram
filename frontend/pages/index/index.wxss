/* 容器 */
.container {
  padding: 0 12rpx;
}

/* 定位栏 - 更紧凑 */
.location-bar {
  display: flex;
  align-items: center;
  padding: 8rpx 16rpx;
  background: #fff3e0;
  border-radius: 6rpx;
  margin-bottom: 8rpx;
}
.location-icon { font-size: 24rpx; margin-right: 6rpx; }
.location-text { font-size: 22rpx; color: #e65100; font-weight: 500; }

/* 标题 - 极致紧凑 */
.header {
  text-align: center;
  padding: 16rpx 0;
  background: linear-gradient(135deg, #ff6b6b 0%, #ee5a5a 100%);
  border-radius: 0 0 20rpx 20rpx;
  margin: 0 -12rpx 10rpx -12rpx;
}
.title { font-size: 32rpx; font-weight: bold; color: white; display: block; }
.subtitle { font-size: 20rpx; color: rgba(255,255,255,0.8); display: block; }

/* 卡片 */
.card { background: white; border-radius: 12rpx; padding: 12rpx 16rpx; margin-bottom: 10rpx; box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04); }
.card-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 8rpx; }
.card-title { font-size: 26rpx; font-weight: bold; color: #333; }
.card-more { font-size: 20rpx; color: #ff6b6b; }
.fruit-count { font-size: 20rpx; color: #999; }

/* 全部水果 - 6列填满整屏 */
.fruit-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 6rpx;
}
.fruit-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 8rpx 2rpx;
  background: #f8f9fa;
  border-radius: 10rpx;
  width: calc(16.6667% - 5rpx);  /* 6列，填满整屏无空白 */
  box-sizing: border-box;
  min-height: 70rpx;
}
.fruit-hover { background: #ffe0e0; }
.fruit-emoji { font-size: 28rpx; line-height: 1.2; }
.fruit-name { font-size: 18rpx; color: #333; line-height: 1.2; margin-top: 2rpx; }

/* 实时价格对比 */
.store-name-row { display: flex; align-items: center; }
.region-tag {
  display: inline-block;
  padding: 1rpx 8rpx;
  background: #e3f2fd;
  color: #1976d2;
  font-size: 16rpx;
  border-radius: 4rpx;
  margin-left: 6rpx;
}

.price-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}
.price-item:last-child { border-bottom: none; }
.price-left { flex: 1; min-width: 0; }
.store-name { font-size: 24rpx; color: #333; display: block; }
.store-type { font-size: 18rpx; color: #999; margin-top: 2rpx; display: block; }
.price-right { display: flex; flex-direction: column; align-items: flex-end; flex-shrink: 0; }
.price-value { font-size: 30rpx; font-weight: bold; color: #ff6b6b; }

/* 等级标签 */
.grade-tag {
  font-size: 18rpx;
  padding: 2rpx 10rpx;
  border-radius: 6rpx;
  color: white;
  margin-top: 4rpx;
}
.grade-A { background: #ff6b6b; }
.grade-B { background: #ff9800; }
.grade-C { background: #999; }

/* 等级说明 - 行内紧凑 */
.grade-legend {
  display: flex;
  justify-content: flex-start;
  gap: 16rpx;
  padding: 8rpx 0;
  margin-bottom: 4rpx;
  border-bottom: 1rpx dashed #eee;
}
.legend-item { display: flex; align-items: center; }
.legend-desc { font-size: 18rpx; color: #888; margin-left: 4rpx; }

/* 空状态 */
.empty-text { text-align: center; color: #999; padding: 16rpx; font-size: 22rpx; }

/* 重试按钮 */
.retry-btn {
  display: inline-block;
  margin-top: 10rpx;
  padding: 10rpx 36rpx;
  background: linear-gradient(135deg, #ff6b6b 0%, #ee5a5a 100%);
  color: white;
  border-radius: 24rpx;
  font-size: 22rpx;
}

/* 使用指南 */
.guide-list { display: flex; justify-content: space-around; }
.guide-item { display: flex; flex-direction: column; align-items: center; padding: 8rpx 16rpx; border-radius: 8rpx; }
.guide-hover { background: #f0f0f0; }
.guide-icon { font-size: 32rpx; }
.guide-text { font-size: 18rpx; color: #666; margin-top: 2rpx; }