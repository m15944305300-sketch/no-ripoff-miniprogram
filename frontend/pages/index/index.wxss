/* 定位栏 */
.location-bar {
  display: flex;
  align-items: center;
  padding: 12rpx 20rpx;
  background: #fff3e0;
  border-radius: 8rpx;
  margin-bottom: 16rpx;
}

.location-icon {
  font-size: 28rpx;
  margin-right: 8rpx;
}

.location-text {
  font-size: 26rpx;
  color: #e65100;
  font-weight: 500;
}

/* 商超名称行 */
.store-name-row {
  display: flex;
  align-items: center;
}

/* 周边县市标签 */
.region-tag {
  display: inline-block;
  padding: 2rpx 10rpx;
  background: #e3f2fd;
  color: #1976d2;
  font-size: 18rpx;
  border-radius: 6rpx;
  margin-left: 8rpx;
}

.header {
  text-align: center;
  padding: 40rpx 0;
  background: linear-gradient(135deg, #ff6b6b 0%, #ee5a5a 100%);
  border-radius: 0 0 32rpx 32rpx;
  margin: -20rpx -20rpx 20rpx -20rpx;
}

.title {
  font-size: 44rpx;
  font-weight: bold;
  color: white;
  display: block;
}

.subtitle {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-top: 8rpx;
  display: block;
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.card-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
}

.card-more {
  font-size: 24rpx;
  color: #ff6b6b;
}

.fruit-count {
  font-size: 24rpx;
  color: #999;
}

/* 全部水果网格布局 */
.fruit-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.fruit-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx 8rpx;
  background: #f8f9fa;
  border-radius: 16rpx;
  width: calc(25% - 12rpx);  /* 每行4个 */
  box-sizing: border-box;
}

.fruit-hover {
  background: #ffe0e0;
}

.fruit-icon {
  font-size: 48rpx;
  margin-bottom: 8rpx;
}

.fruit-name {
  font-size: 22rpx;
  color: #333;
  margin-bottom: 4rpx;
}

.fruit-category {
  font-size: 18rpx;
  color: #bbb;
}

.price-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.price-item:last-child {
  border-bottom: none;
}

.store-name {
  font-size: 28rpx;
  color: #333;
  display: block;
}

.store-type {
  font-size: 22rpx;
  color: #999;
  margin-top: 4rpx;
  display: block;
}

.price-value {
  font-size: 36rpx;
  font-weight: bold;
  color: #ff6b6b;
}

.empty-text {
  text-align: center;
  color: #999;
  padding: 40rpx;
  font-size: 26rpx;
}

/* 重试按钮 */
.retry-btn {
  display: inline-block;
  margin-top: 16rpx;
  padding: 16rpx 48rpx;
  background: linear-gradient(135deg, #ff6b6b 0%, #ee5a5a 100%);
  color: white;
  border-radius: 32rpx;
  font-size: 26rpx;
}

/* 等级说明 */
.grade-legend {
  background: #f8f9fa;
  border-radius: 12rpx;
  padding: 16rpx 20rpx;
  margin-bottom: 20rpx;
}

.legend-item {
  display: flex;
  align-items: center;
  margin-bottom: 8rpx;
}

.legend-item:last-child {
  margin-bottom: 0;
}

.legend-desc {
  font-size: 20rpx;
  color: #888;
  margin-left: 12rpx;
}

/* 使用指南 */
.guide-list {
  display: flex;
  justify-content: space-around;
}

.guide-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx 24rpx;
  border-radius: 12rpx;
  transition: background 0.2s;
}

/* 点击反馈 */
.guide-hover {
  background: #f0f0f0;
}

.guide-icon {
  font-size: 40rpx;
  margin-bottom: 8rpx;
}

.guide-text {
  font-size: 22rpx;
  color: #666;
}
