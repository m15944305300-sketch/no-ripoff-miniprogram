/* 容器 */
.container {
  padding: 0 10rpx;
}

/* 标题：定位并入header */
.header {
  text-align: center;
  padding: 10rpx 0 12rpx 0;
  background: linear-gradient(135deg, #ff6b6b 0%, #ee5a5a 100%);
  border-radius: 0 0 16rpx 16rpx;
  margin: 0 -10rpx 8rpx -10rpx;
}
.header-top {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 4rpx;
}
.location-icon { font-size: 20rpx; margin-right: 4rpx; }
.location-text { font-size: 20rpx; color: rgba(255,255,255,0.85); }
.title { font-size: 30rpx; font-weight: bold; color: white; display: block; }
.subtitle { font-size: 18rpx; color: rgba(255,255,255,0.7); display: block; }

/* 卡片 */
.card { background: white; border-radius: 10rpx; padding: 10rpx 12rpx; margin-bottom: 6rpx; box-shadow: 0 1rpx 6rpx rgba(0,0,0,0.04); }
.card-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 6rpx; }
.card-title { font-size: 24rpx; font-weight: bold; color: #333; }
.card-more { font-size: 18rpx; color: #ff6b6b; }
.fruit-count { font-size: 18rpx; color: #999; }

/* 全部水果 - 精确6列，零浪费
   6列 = 5个间隙。gap: 6rpx, 5*6=30rpx间隙
   每个格子 = (100% - 30rpx) / 6
*/
.fruit-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 6rpx;
}
.fruit-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 6rpx 2rpx;
  background: #f8f9fa;
  border-radius: 8rpx;
  width: calc((100% - 30rpx) / 6);  /* 精确6列 */
  box-sizing: border-box;
  min-height: 64rpx;
}
.fruit-hover { background: #ffe0e0; }
.fruit-emoji { font-size: 26rpx; line-height: 1.1; }
.fruit-name { font-size: 16rpx; color: #333; line-height: 1.1; margin-top: 1rpx; }

/* 实时价格对比 */
.store-name-row { display: flex; align-items: center; }
.region-tag {
  display: inline-block;
  padding: 1rpx 6rpx;
  background: #e3f2fd;
  color: #1976d2;
  font-size: 14rpx;
  border-radius: 4rpx;
  margin-left: 4rpx;
}
.price-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 10rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}
.price-item:last-child { border-bottom: none; }
.price-left { flex: 1; min-width: 0; }
.store-name { font-size: 22rpx; color: #333; display: block; }
.store-type { font-size: 16rpx; color: #999; margin-top: 2rpx; display: block; }
.price-right { display: flex; flex-direction: column; align-items: flex-end; flex-shrink: 0; }
.price-value { font-size: 28rpx; font-weight: bold; color: #ff6b6b; }

/* 等级标签 */
.grade-tag {
  font-size: 16rpx;
  padding: 2rpx 8rpx;
  border-radius: 4rpx;
  color: white;
  margin-top: 2rpx;
}
.grade-A { background: #ff6b6b; }
.grade-B { background: #ff9800; }
.grade-C { background: #999; }

/* 等级说明 - 行内紧凑 */
.grade-legend {
  display: flex;
  justify-content: flex-start;
  gap: 12rpx;
  padding: 6rpx 0;
  margin-bottom: 2rpx;
  border-bottom: 1rpx dashed #eee;
}
.legend-item { display: flex; align-items: center; }
.legend-desc { font-size: 16rpx; color: #888; margin-left: 2rpx; }

/* 空状态 */
.empty-text { text-align: center; color: #999; padding: 12rpx; font-size: 20rpx; }

/* 重试按钮 */
.retry-btn {
  display: inline-block;
  margin-top: 8rpx;
  padding: 8rpx 30rpx;
  background: linear-gradient(135deg, #ff6b6b 0%, #ee5a5a 100%);
  color: white;
  border-radius: 20rpx;
  font-size: 20rpx;
}

/* 使用指南 - 单行紧凑 */
.guide-row {
  display: flex;
  justify-content: space-around;
  padding: 12rpx 0;
}
.guide-item { display: flex; align-items: center; padding: 6rpx 12rpx; border-radius: 6rpx; }
.guide-hover { background: #f0f0f0; }
.guide-icon { font-size: 24rpx; margin-right: 4rpx; }
.guide-text { font-size: 18rpx; color: #666; }