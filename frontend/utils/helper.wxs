// WXS 工具模块：提供 emoji 映射与等级处理
// 注意：WXS 不支持 ES6 语法，只能用 var / function
var emojis = {
  // 仁果类
  '苹果': '🍎', '梨': '🍐', '苹果梨': '🍐',
  // 核果类
  '桃子': '🍑', '李子': '🫐', '杏子': '🟠', '樱桃': '🍒', '车厘子': '🍒',
  // 浆果类
  '葡萄': '🍇', '提子': '🍇', '草莓': '🍓', '蓝莓': '🫐',
  '猕猴桃': '🥝', '无花果': '🌿', '石榴': '🟠',
  // 瓜类
  '西瓜': '🍉', '哈密瓜': '🍈', '香瓜': '🍈',
  // 柑橘类
  '橙子': '🍊', '柚子': '🍊', '柠檬': '🍋',
  // 热带水果
  '香蕉': '🍌', '芒果': '🥭', '榴莲': '🥥', '菠萝': '🍍',
  '山竹': '🟣', '荔枝': '🔴', '龙眼': '🟤', '火龙果': '🐉',
  '木瓜': '🟠', '椰子': '🥥', '百香果': '🟣', '牛油果': '🥑',
  '莲雾': '🔴', '释迦果': '🟢',
  // 其他
  '柿子': '🟠', '枣': '🔴'
}

module.exports = {
  getEmoji: function (name) {
    return emojis[name] || '🍎'
  },
  gradeShort: function (grade) {
    if (!grade) return ''
    return grade.replace('级', '')
  },
  isExternal: function (region) {
    return region !== '延吉市'
  }
}
